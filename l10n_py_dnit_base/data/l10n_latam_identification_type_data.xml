<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="it_ruc" model="l10n_latam.identification.type">
        <field name="name">RUC</field>
        <field name="description">Registro Único de Contribuyentes</field>
        <field name="country_id" ref="base.py"/>
        <field name="is_vat" eval="True"/>
        <field name="sequence">1</field>
    </record>

    <record id="it_ci" model="l10n_latam.identification.type">
        <field name="name">Cédula de Identidad</field>
        <field name="country_id" ref="base.py"/>
        <field name="sequence">2</field>
    </record>

    <record id="it_pasaporte" model="l10n_latam.identification.type">
        <field name="name">Pasaporte</field>
        <field name="country_id" ref="base.py"/>
        <field name="sequence">3</field>
    </record>

    <record id="it_carnet_residencia" model="l10n_latam.identification.type">
        <field name="name">Carnet de Residencia</field>
        <field name="country_id" ref="base.py"/>
        <field name="sequence">4</field>
    </record>

    <record id="it_innominado" model="l10n_latam.identification.type">
        <field name="name">Sin Nombre / Innominado</field>
        <field name="country_id" ref="base.py"/>
        <field name="sequence">5</field>
    </record>

</odoo>
