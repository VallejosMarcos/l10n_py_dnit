<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_l10n_py_edi" model="ir.ui.view">
        <field name="name">account.move.form.l10n.py.edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_py_dnit_account.view_move_form_l10n_py"/>
        <field name="arch" type="xml">
            <field name="l10n_py_full_number" position="after">
                <field name="l10n_py_edi_state" invisible="country_code != 'PY'"/>
                <field name="l10n_py_edi_cdc" invisible="not l10n_py_edi_cdc"/>
            </field>
        </field>
    </record>

</odoo>
