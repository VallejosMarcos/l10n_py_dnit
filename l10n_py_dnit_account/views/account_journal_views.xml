<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_journal_form_l10n_py" model="ir.ui.view">
        <field name="name">account.journal.form.l10n.py</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <field name="code" position="after">
                <field name="l10n_py_establishment"
                       invisible="type not in ('sale', 'purchase')"/>
                <field name="l10n_py_expedition_point"
                       invisible="type not in ('sale', 'purchase')"/>
            </field>
        </field>
    </record>

</odoo>
